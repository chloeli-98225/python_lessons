
import os


filenames = os.listdir('list')
print(filenames)


for filename in filenames:
	name, extension = os.path.splitext(filename) #多重設值指令:  xx.yy = cc.bb
	print('Name:',name)
	print('Extension:',extension)

	new_filename = name + '_new' + extension
	print(new_filename)

#splitext 當中的ext即是
#extension = 副檔名

#上面示範程式碼僅印出，透過詢問ai程式碼如何寫，下面示範的是可以確實改變檔案名稱的程式碼：

import os

filenames = os.listdir('list')

for filename in filenames:
	name, extension = os.path.splitext(filename)
	new_filename = name + '_new' + extension
	
	old_file_path = os.path.join('list',filename) #終端機呈現修改前的路徑：list/預約細項(5).xlsx  list/預約細項(4).xlsx
	new_file_path = os.path.join('list',new_filename) #終端機呈現修改後的路徑：list/預約細項 (5)_new.xlsx  list/預約細項 (4)_new.xlsx


	os.rename(old_file_path,new_file_path)

# old_file_path = os.path.join('list',filename) 相等於  file_path = 'list' + '/' + filename


